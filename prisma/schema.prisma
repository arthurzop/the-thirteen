generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

type CloudinaryImage {
  url      String
  publicId String
  width    Int
  height   Int
}

type GalleryImage {
  url      String
  publicId String
  alt      String?
  width    Int
  height   Int
}

type ExternalLink {
  label String
  url   String
}

model Reference {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String  @unique
  description String?

  mainImage CloudinaryImage
  gallery   GalleryImage[]
  links     ExternalLink[]

  typeId String @db.ObjectId
  type   Type   @relation(fields: [typeId], references: [id])

  areaIds String[] @db.ObjectId
  areas   Area[]   @relation(fields: [areaIds], references: [id])

  tagIds String[] @db.ObjectId
  tags   Tag[]    @relation(fields: [tagIds], references: [id])

  collectionIds String[]     @db.ObjectId
  collections   Collection[] @relation(fields: [collectionIds], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  @@index([typeId])
  @@index([areaIds])
  @@index([tagIds])
  @@index([title, description])
}

model Collection {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String  @unique
  description String?

  coverImage CloudinaryImage

  referenceIds String[]    @db.ObjectId
  references   Reference[] @relation(fields: [referenceIds], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
}

model Type {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  slug String @unique

  areas      Area[]
  references Reference[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Area {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  slug String

  typeId String @db.ObjectId
  type   Type   @relation(fields: [typeId], references: [id])

  referenceIds String[]    @db.ObjectId
  references   Reference[] @relation(fields: [referenceIds], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([typeId, slug])
  @@index([typeId])
}

model Tag {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  slug String @unique

  referenceIds String[]    @db.ObjectId
  references   Reference[] @relation(fields: [referenceIds], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  passwordHash String
  updatedAt    DateTime @updatedAt
}